{
  "name": "rublevsky-studio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare",
    "dev:worker": "wrangler dev --port 8771",
    "preview:worker": "pnpm build:worker && pnpm dev:worker",
    "preview:worker:remote": "pnpm build:worker && pnpm dev:worker -- --remote",
    "deploy": "opennextjs-cloudflare && wrangler deploy",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply rublevsky-studio-storage --local",
    "db:migrate:remote": "wrangler d1 migrations apply rublevsky-studio-storage --remote"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@next/env": "^15.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@types/gsap": "^1.20.2",
    "bcrypt-ts-edge": "^3.0.1",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "framer-motion": "^12.0.3",
    "gsap": "^3.12.7",
    "lucide-react": "^0.474.0",
    "next": "14.2.5",
    "next-auth": "5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "split-type": "^0.3.4",
    "swiper": "^11.2.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^0.5.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^10.0.1",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "wrangler": "^3.30.1"
  }
}
