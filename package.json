{
  "name": "rublevsky-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "dev:worker": "wrangler dev --port 8771",
    "preview:worker": "pnpm build:worker && pnpm dev:worker",
    "deploy": "pnpm opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply rublevsky-studio-storage --local",
    "db:migrate:prod": "wrangler d1 migrations apply rublevsky-studio-storage --remote",
    "db:seed": "tsx scripts/seedDatabase.ts",
    "db:seed:prod": "tsx scripts/seedDatabase.ts --remote",
    "db:reset": "rm -rf .wrangler/state/v3/d1 drizzle && tsx scripts/resetDatabase.ts && pnpm db:generate && pnpm db:migrate:local",
    "db:reset:prod": "rm -rf drizzle && tsx scripts/resetDatabase.ts --remote && pnpm db:generate && pnpm db:migrate:prod",
    "email": "email dev --dir emails"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.15",
    "@calcom/embed-react": "^1.5.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-email/components": "0.0.33",
    "@tabler/icons-react": "^3.31.0",
    "@tanstack/react-table": "^8.21.2",
    "better-auth": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookies-next": "^5.1.0",
    "drizzle-orm": "^0.39.3",
    "embla-carousel-react": "^8.5.2",
    "lucide-react": "^0.474.0",
    "motion": "^12.6.2",
    "next": "15.3.0-canary.29",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.1",
    "resend": "^4.1.2",
    "sonner": "^2.0.1",
    "split-type": "^0.3.4",
    "swiper": "^11.2.3",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@eslint/eslintrc": "^3",
    "@million/lint": "^1.0.14",
    "@opennextjs/cloudflare": "^0.6.6",
    "@tailwindcss/postcss": "^4.0.15",
    "@tailwindcss/typography": "0.5.0-alpha.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.29.0",
    "better-sqlite3": "^11.8.1",
    "caniuse-lite": "^1.0.30001707",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "react-email": "3.0.7",
    "tailwindcss": "^4.0.15",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "wrangler": "^4.6.0"
  }
}
