{
  "name": "rublevsky-studio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare",
    "dev:worker": "wrangler dev --port 8771",
    "preview:worker": "pnpm build:worker && pnpm dev:worker",
    "deploy": "opennextjs-cloudflare && wrangler deploy",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply rublevsky-studio-storage --local",
    "db:migrate:prod": "wrangler d1 migrations apply rublevsky-studio-storage --remote",
    "db:seed": "tsx scripts/seedDatabase.ts",
    "db:seed:prod": "tsx scripts/seedDatabase.ts --remote",
    "db:reset": "rm -rf .wrangler/state/v3/d1 drizzle && tsx scripts/resetDatabase.ts && pnpm db:generate && pnpm db:migrate:local",
    "db:reset:prod": "rm -rf drizzle && tsx scripts/resetDatabase.ts --remote && pnpm db:generate && pnpm db:migrate:prod",
    "email": "email dev --dir emails"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.15",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@million/lint": "^1.0.14",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-email/components": "0.0.33",
    "@types/gsap": "^1.20.2",
    "better-auth": "^1.2.4",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookies-next": "^5.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "framer-motion": "^12.5.0",
    "gsap": "^3.12.7",
    "lucide-react": "^0.474.0",
    "next": "14.2.5",
    "next-themes": "^0.4.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "resend": "^4.1.2",
    "sonner": "^2.0.1",
    "split-type": "^0.3.4",
    "swiper": "^11.2.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^0.5.3",
    "@tailwindcss/typography": "^0.5.16",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^10.0.1",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "react-email": "3.0.7",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "wrangler": "^4.0.0"
  }
}
